# ═══════════════════════════════════════════════════════════════
# LLM Provider（必填其一；⭐默认示例为 DeepSeek 官方 API）
# ═══════════════════════════════════════════════════════════════
#
# ⭐ 免费层 failover → b.ai → DeepSeek（可选链路）
# 1) 免费 OpenAI 兼容（有 key 才启用，顺序 LLM_FREE_ORDER）：
#    Groq / Cerebras / Gemini / OpenRouter(:free) / SambaNova
# 2) BAI_API_KEY + BAI_MODEL：再试 b.ai（完整 v1 prompt）
# 3) 最后：下方 LLM_PROVIDER（建议 DeepSeek 官方）
# 盯盘 MONITOR_AI_FREE_ONLY=true 时只用第 1 步，不回落付费。
#
# GROQ_API_KEY=gsk-xxx
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MAX_TOKENS=4096
# LLM_TRY_GROQ_FIRST=true
#
# # Cerebras 免费额度较大：https://cloud.cerebras.ai
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=gpt-oss-120b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
#
# # Google AI Studio：https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#
# # OpenRouter 免费模型：https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#
# # SambaNova：https://cloud.sambanova.ai/apis
# SAMBANOVA_API_KEY=
# SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
# SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
#
# # NVIDIA NIM：https://build.nvidia.com
# NVIDIA_API_KEY=
# NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
#
# LLM_FREE_ORDER=nvidia,groq,cerebras,openrouter,sambanova,gemini
#
# BAI_API_KEY=b.ai的密钥
# BAI_BASE_URL=https://api.b.ai/v1
# BAI_MODEL=claude-sonnet-4.6
# LLM_TRY_BAI_AFTER_GROQ=true

# ─────────────────────────────────────
# 选项 A：DeepSeek 官方（⭐推荐：OpenAI 兼容，中文与性价比）
# 控制台：https://platform.deepseek.com → API keys
# ─────────────────────────────────────
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-在这里粘贴你的key
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
# V4 思考模式（与官方 Python 示例一致：https://api-docs.deepseek.com/zh-cn/）
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_ENABLED=true
# Flash 若报错可试：DEEPSEEK_THINKING_ENABLED=false 或 DEEPSEEK_REASONING_EFFORT=
# 更强能力：LLM_MODEL=deepseek-v4-pro

# ─────────────────────────────────────
# 选项 B：仅 b.ai（不用 Groq 优先时，与「链路等价」的两键线路）
# ─────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.b.ai/v1
# OPENAI_API_KEY=b.ai的密钥
# LLM_MODEL=claude-sonnet-4.6
# LLM_TRY_GROQ_FIRST=false
# LLM_TRY_BAI_AFTER_GROQ=false

# ─────────────────────────────────────
# 选项 B²：b.ai 作为 Groq 之后的第二段（与 GROQ_* 同时配）
# 见上方 BAI_*；主线路保持 DeepSeek 即可。

# ─────────────────────────────────────
# 选项 C：Anthropic 官方 Claude
# ─────────────────────────────────────
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-xxx
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_BASE_URL=

# ─────────────────────────────────────
# 选项 D：仅 Groq（不配置 GROQ_API_KEY、不设优先时，与下方等价）
# ─────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk-xxx
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_TRY_GROQ_FIRST=false

# ─────────────────────────────────────
# 选项 E：OpenRouter
# ─────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-v1-xxx
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ─────────────────────────────────────
# 选项 F：Ollama 本地
# ─────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# LLM_MODEL=qwen2.5:14b

# ─────────────────────────────────────
# 选项 G：OpenAI 官方
# ─────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=

# ═══════════════════════════════════════════════════════════════
# 通用 LLM 参数
# ═══════════════════════════════════════════════════════════════
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000
# 提示词版本：v1=完整（含波段锁点短纪律）；Groq 前置层仍用 prompts/system_groq.md（短版）
LLM_PROMPT_VERSION=v1

# ═══════════════════════════════════════════════════════════════
# 数据源
# ═══════════════════════════════════════════════════════════════
EXCHANGE=binance
# 默认观察列表（页面初始值；MONITOR_DAEMON_SYMBOLS 为空时，常驻盯盘也用这份）
# Web 固定 U 本位永续，按需增删即可
DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT,SUI/USDT,UNI/USDT
DATA_CACHE_DIR=.cache/data
DATA_CACHE_TTL_MINUTES=5

# ═══════════════════════════════════════════════════════════════
# 分析 / 会话参数
# ═══════════════════════════════════════════════════════════════
DEFAULT_TIMEFRAME=4h
VERIFICATION_DELAY_HOURS=72
SESSION_EXPIRE_HOURS=168

# 风控默认值（仅作 AI 建议参考；Web3「头仓/补仓计算器」也可对照这些数量级）
MAX_RISK_PER_TRADE_PCT=1
MAX_LEVERAGE=10
DEFAULT_ACCOUNT_USD=10000

# ═══════════════════════════════════════════════════════════════
# 实时监控（analyst monitor / Web 常驻盯盘）
# 双线反转 + 规则引擎 + cycle_switch + 可选 AI 候选确认
# ═══════════════════════════════════════════════════════════════
# 市场与主图默认周期（页面切周期不影响常驻 MONITOR_DAEMON_TIMEFRAMES）
MONITOR_MARKET=futures
MONITOR_TIMEFRAME=15m

# —— 双线反转参数（Kelly / 止损 / 趋势过滤）——
MONITOR_KELLY_SCALE=0.25
MONITOR_STOP_BUFFER_PCT=2.0
# 止损缓冲被 ATR 封顶（min(2%, ATR×该值)）；0=禁用
MONITOR_STOP_BUFFER_ATR_MULT=1.0
MONITOR_TAKE_PROFIT_R=2.0
# 现价超出突破位该倍数 ATR 就不追；0=禁用
MONITOR_MAX_CHASE_ATR=1.5
MONITOR_EMA_TREND_PERIOD=200
MONITOR_REQUIRE_EMA200=true
# 可选：EMA200 还需同向倾斜才入场（更严，也会滤掉部分盈利单）
MONITOR_REQUIRE_EMA_SLOPE=false
MONITOR_TRAIL_TO_8R=false
MONITOR_REQUIRE_FIB_ZONE=false
# 量能冲突过滤（默认开）
MONITOR_REQUIRE_VOLUME=true
# ADX 趋势强度：低于阈值视为震荡，跳过双线入场
MONITOR_REQUIRE_ADX=true
MONITOR_ADX_PERIOD=14
MONITOR_ADX_MIN=20
# 条件胜率：更新先验、过低跳过、按后验缩放纸面仓位
MONITOR_USE_CONDITIONAL_EDGE=true
MONITOR_MIN_CONDITIONAL_WIN_RATE=0.42

# —— 无 AI 规则提醒（命中一律上页面；是否进 TG 看下方白名单）——
MONITOR_RULES_ENABLED=true
MONITOR_RULE_MACD=true
MONITOR_RULE_EMA_STACK=true
MONITOR_RULE_BOLL=true
MONITOR_RULE_VOLUME=true
MONITOR_RULE_STRUCTURE_TOUCH=true
MONITOR_RULE_STRUCTURE_FLIP=true
MONITOR_RULE_FIB_ZONE=true
MONITOR_RULE_BASELINE=true
MONITOR_RULE_BREAK_LEVEL=true
MONITOR_RULE_FUNDING=true
MONITOR_RULE_PREMIUM=true
MONITOR_FUNDING_EXTREME_PCT=0.05
MONITOR_PREMIUM_EXTREME_PCT=0.30
# 放量告警阈值（×20 根均量）
MONITOR_VOLUME_SPIKE_RATIO=2.0
# 同一支撑/阻力触及后的冷却根数（防页面刷屏）
MONITOR_TOUCH_COOLDOWN_BARS=12

# —— Telegram 推送策略 ——
# 白名单：仅这些 rule 名走 TG（页面仍显示全部）。空字符串=全部规则推 TG（旧行为）
#   ai_plan = 候选后 AI 盯盘点评（long/short）；macd_cross/volume/… = 异动规则
# cycle_switch 仓位变化只上页面并触发 AI 候选，不直推 TG
# 不受白名单限制：cycle_outlook = 每天提醒当前周期位置
MONITOR_TG_TRADE_RULES=ai_plan,macd_cross,ema_stack,volume,boll_break,break_level,funding_extreme

# —— AI 候选确认（控成本）——
# true：收盘出现「双线」或「规则命中」或「cycle_switch 仓位变」时才调 LLM
# AI 结论 long/short → 页面+TG「盯盘点评」（不开纸面仓）；wait → 不推
MONITOR_AI_ON_CANDIDATE=true
# 同品种 + AI 分析周期冷却分钟（15m 候选会映射到 1h 分析；防放量每根刷 AI）
MONITOR_AI_COOLDOWN_MINUTES=240
# true（推荐）：盯盘自动确认只用免费层（Groq/Cerebras/Gemini/OpenRouter/SambaNova），
# 失败不回落 DeepSeek/b.ai/Anthropic；失败时会推页面+TG 告警（不静默）
# 手动点「分析」仍走完整付费链路
MONITOR_AI_FREE_ONLY=true

# —— 纸面模拟炒币（非真金）——
# 只跟规则策略开仓（双线 / cycle_switch）；AI 只点评不开仓
MONITOR_PAPER_ENABLED=true
MONITOR_PAPER_EQUITY=100
# 单笔风险占权益比例（仓位 = risk_usd / |entry-stop|；cycle 无止损时用 2% 估仓）
MONITOR_PAPER_RISK_PCT=0.01
# 开平各收一次手续费（bps，4=0.04%）
MONITOR_PAPER_FEE_BPS=4
# 纸面杠杆（保证金=名义/杠杆；持仓页显示保证金收益率）
MONITOR_PAPER_LEVERAGE=5
# 最多同时持仓笔数（去重键 = 品种×策略，可同币多策略各一仓）
MONITOR_PAPER_MAX_POSITIONS=12
# 跟单来源：double_line,cycle_switch（不要加 ai_plan）
MONITOR_PAPER_SOURCES=cycle_switch,xs_momentum,funding_carry
# 双线纸面仅这些周期（防 1m 噪声）；空=不限制
MONITOR_PAPER_DOUBLE_LINE_TFS=15m,1h,4h
# 单笔保证金 ≤ 权益×该比例（止损过窄时缩仓）
MONITOR_PAPER_MAX_MARGIN_PCT=0.15
# 双线止损后同品种同向冷却（分钟）；0=关闭
MONITOR_PAPER_SL_COOLDOWN_MINUTES=120
# 开/平仓是否推 Telegram（文案带「纸面」）
MONITOR_PAPER_TG=true

# —— 风控熔断 ——
# 单日权益回撤 ≥ 该百分比 → 今日停开新仓（次日 UTC 自动复位）；0=关
PAPER_DAILY_LOSS_LIMIT_PCT=5.0
# 熔断时是否顺带全平现有仓位（默认只停新仓）
PAPER_FLATTEN_ON_DAILY_FUSE=false
# 单策略已实现盈亏从峰值回撤 ≥ 初始权益该百分比 → 停用该策略
# 恢复：analyst paper-fuse clear <策略名>
PAPER_STRATEGY_DD_DISABLE_PCT=20.0
# 组合总名义敞口 / 权益 上限（BTC/ETH/SOL 高相关，敞口会叠加）；0=关
PAPER_MAX_GROSS_EXPOSURE=2.0

# —— 横截面动量实时跟单（BTC 4h 收盘评估，每周调仓） ——
MONITOR_XS_ENABLED=true
# 观察池；空=全部盯盘品种
MONITOR_XS_SYMBOLS=
MONITOR_XS_TOP_N=2
MONITOR_XS_REBALANCE_HOURS=168
MONITOR_XS_BEAR_SHORT=true

# —— 资金费套利实时跟单（1h 收盘评估，8h 结算入账） ——
MONITOR_CARRY_ENABLED=true
MONITOR_CARRY_SYMBOLS=BTC/USDT,ETH/USDT
# 合计名义 = 权益 × 该比例（各币均分）
MONITOR_CARRY_ALLOC_PCT=0.15

# —— 牛熊周期策略 cycle_switch ——
# 各盯盘币对在该周期收盘评估仓位（相位用 BTC 定调；执行看各币自己的 K 线）
# 相对上一根 K 仓位变化 → 页面告警 + AI 候选点评（不直推 TG；纸面直接跟仓位）
MONITOR_CYCLE_SWITCH_ENABLED=true
MONITOR_CYCLE_SWITCH_TIMEFRAME=4h
# cycle_switch 跟单/仓位告警白名单（空=全部盯盘品种）；默认不含弱 beta
MONITOR_CYCLE_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
# 每天提醒当前周期位置（与「某币交易点」分开）：UTC 每天最多推 TG 一次
MONITOR_CYCLE_OUTLOOK_ENABLED=true

# —— 常驻盯盘（关网页也继续跑，需进程在线）——
MONITOR_ALWAYS_ON=false
# 常驻品种；空则用 DEFAULT_SYMBOLS；页面观察列表在常驻模式下可热更新写入
# MONITOR_DAEMON_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
# 常驻多级别；每个品种×周期各一条 WS；空则仅 MONITOR_TIMEFRAME
MONITOR_DAEMON_TIMEFRAMES=15m,1h,4h
# 页面图表可选周期（不含 1m/5m 等短周期）
MONITOR_CHART_TIMEFRAMES=15m,1h,4h

# —— 市场日程（独立「日程」页 + TG 提前提醒）——
MONITOR_SCHEDULE_ENABLED=true
MONITOR_SCHEDULE_TG=true
# 时段 / 资金费 / 宏观事件提前提醒（分钟，逗号分隔）
MONITOR_SCHEDULE_SESSION_LEADS=30,15
MONITOR_SCHEDULE_FUNDING_LEADS=30
MONITOR_SCHEDULE_MACRO_LEADS=60,30,15
MONITOR_SCHEDULE_MACRO_CURRENCIES=USD
MONITOR_SCHEDULE_MACRO_IMPACTS=High

# Telegram（推送必备）
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════
# 数据库 & 日志
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=sqlite:///./analyst.db
LOG_LEVEL=INFO
LOG_FILE=.logs/analyst.log
